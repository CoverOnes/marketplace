# Marketplace service environment configuration
# Copy to .env and fill in real values (NEVER commit .env)

# Server
MARKETPLACE_PORT=8081
MARKETPLACE_ENV=development

# Postgres (required)
MARKETPLACE_POSTGRES_DSN=postgres://marketplace:REPLACE_ME@localhost:5432/marketplace?sslmode=disable

# Postgres schema isolation (optional — default empty = public schema)
# Set to "marketplace" when sharing one Aiven database with sibling services.
# Each service gets its own schema; golang-migrate schema_migrations table is
# also isolated per schema, preventing version-table collisions.
# Only [a-zA-Z0-9_] characters are allowed; reserved words (e.g. "user") are
# accepted and automatically double-quoted in SQL by pgx.Identifier.Sanitize().
# MARKETPLACE_DB_SCHEMA=marketplace

# Postgres connection pool sizing (optional — defaults: max=10, min=2)
# Reduce when running 8+ services against a small Aiven plan to stay within
# the plan's max_connections limit (e.g. MARKETPLACE_DB_MAX_CONNS=3).
# MARKETPLACE_DB_MAX_CONNS=10
# MARKETPLACE_DB_MIN_CONNS=2

# Redis (optional — noop event publish + in-process rate limiter when unset)
MARKETPLACE_REDIS_URL=redis://localhost:6379/0

# Workspace service (server-to-server contract creation on AcceptBid — M-2)
# Required in production: when MARKETPLACE_ENV != development, both MUST be set
# or config validation fails (prevents silent fail-open where AcceptBid succeeds
# but no workspace contract is ever created).
# workspace service base URL for S2S contract creation
MARKETPLACE_WORKSPACE_BASE_URL=
# ≥32 chars, required when base URL is set
MARKETPLACE_WORKSPACE_SERVICE_TOKEN=REPLACE_ME_min32chars

# Gateway-origin identity signature (conventions §24.1 — defense-in-depth)
# MUST equal the gateway's GATEWAY_HMAC_SECRET. ≥32 chars.
# Non-dev (staging/production): REQUIRED — boot fails fast if empty/short.
# Development: may be left empty (verification disabled, mirroring the gateway's
# dev signing-skip). chmod 0600 any file that provides this; env var is canonical.
MARKETPLACE_GATEWAY_HMAC_SECRET=REPLACE_ME_min32chars

# Per-authenticated-user rate limiting (downstream retrofit — gateway IP is shared)
# Set MARKETPLACE_USER_RATE_LIMIT_PER_MIN=0 to disable per-user limiting entirely.
# When non-zero, BURST must also be > 0 (config validation enforces this).
# MARKETPLACE_USER_RATE_LIMIT_PER_MIN=120
# MARKETPLACE_USER_RATE_LIMIT_BURST=20

# Logging
MARKETPLACE_LOG_LEVEL=INFO

# File service (server-to-server attachment registration and presigned URLs — issue #18)
# Required in production when the marketplace accepts listing attachments.
# When MARKETPLACE_FILE_BASE_URL is empty, all file S2S calls are skipped (dev mode).
# file service base URL for S2S attachment registration + presign
MARKETPLACE_FILE_BASE_URL=
# service identifier sent as X-Service-Id header (must match file service ACL entry)
MARKETPLACE_FILE_SERVICE_ID=marketplace
# shared secret sent as X-Service-Token header — ≥32 chars, required when base URL is set
MARKETPLACE_FILE_SERVICE_TOKEN=REPLACE_ME_min32chars

# Embedding API (OpenRouter proxying text-embedding-3-small — issue #25)
# When MARKETPLACE_EMBEDDING_API_KEY is empty, the embedding client is DISABLED
# (returns ErrEmbeddingDisabled; boot continues). Required in non-dev unless
# MARKETPLACE_EMBEDDING_DISABLED=true is set (config validation enforces this).
# API key sent in Authorization: Bearer header — NEVER in the URL.
MARKETPLACE_EMBEDDING_API_KEY=REPLACE_ME
# Embedding model (default: text-embedding-3-small — output dimension 1536).
# MARKETPLACE_EMBEDDING_MODEL=text-embedding-3-small
# Embedding API base URL (default: https://openrouter.ai — /api/v1/embeddings path appended by the client).
# MARKETPLACE_EMBEDDING_BASE_URL=https://openrouter.ai
# Per-request HTTP timeout in seconds (default: 30, range: 1-300).
# MARKETPLACE_EMBEDDING_TIMEOUT_SEC=30
# Set to true to disable embedding in non-dev without an API key.
# MARKETPLACE_EMBEDDING_DISABLED=false
